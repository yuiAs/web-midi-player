{
  "name": "web",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "npm run build && wrangler dev",
    "check": "svelte-check --tsconfig ./tsconfig.app.json && tsc -p tsconfig.node.json",
    "wasm": "wasm-pack build ../core --target web --out-dir ../web/src/wasm --out-name core && wasm-pack build ../core --target web --out-dir ../web/public/wasm --out-name core",
    "wasm:dev": "wasm-pack build ../core --dev --target web --out-dir ../web/src/wasm --out-name core && wasm-pack build ../core --dev --target web --out-dir ../web/public/wasm --out-name core",
    "cloudflare:build": "bash ../cloudflare-build.sh",
    "deploy": "npm run build && wrangler deploy"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.36.3",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tsconfig/svelte": "^5.0.8",
    "@types/audioworklet": "^0.0.100",
    "@types/node": "^24.12.3",
    "svelte": "^5.55.5",
    "svelte-check": "^4.4.8",
    "typescript": "~6.0.2",
    "vite": "^8.0.12",
    "vite-plugin-wasm": "^3.6.0",
    "wrangler": "^4.90.0"
  },
  "dependencies": {
    "@tanstack/svelte-virtual": "^3.13.24",
    "browser-fs-access": "^0.38.0"
  }
}
