root = true

[*]
charset = utf-8
end_of_line = lf
indent_style = space
trim_trailing_whitespace = false

[*.{rs}]
indent_size = 2
insert_final_newline = true

[*.{toml}]
indent_size = 2

[*.{ts,js}]
indent_size = 2
insert_final_newline = true
trim_trailing_whitespace = true

[*.{json,jsonc,jsonl}]
indent_size = 2

[*.{html,css}]
indent_size = 2
